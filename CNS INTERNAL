import javax.crypto.Cipher;
import javax.crypto.SecretKey;
import javax.crypto.SecretKeyFactory;
import javax.crypto.spec.DESKeySpec;

public class DES {

    static Cipher c;

    public static void main(String[] a) throws Exception {
        String k = "12345678";
        String p = "0000000100100011010001010110011110001001101010111100110111101111";

        byte[] eb = enc(p, k);
        byte[] db = dec(eb, k);

        System.out.println("Plaintext :");
        System.out.println(p);
        System.out.println("Ciphertext :");
        System.out.println(bin(eb));
        System.out.println("Decrypted :");
        System.out.println(bin(db));
    }

    static byte[] enc(String t, String k) throws Exception {
        c = Cipher.getInstance("DES/ECB/PKCS5Padding");
        c.init(Cipher.ENCRYPT_MODE, key(k));
        return c.doFinal(t.getBytes());
    }

    static byte[] dec(byte[] t, String k) throws Exception {
        c = Cipher.getInstance("DES/ECB/PKCS5Padding");
        c.init(Cipher.DECRYPT_MODE, key(k));
        return c.doFinal(t);
    }

    static SecretKey key(String k) throws Exception {
        return SecretKeyFactory.getInstance("DES")
                .generateSecret(new DESKeySpec(k.getBytes()));
    }

    static String bin(byte[] b) {
        StringBuilder s = new StringBuilder();
        for (byte x : b)
            for (int i = 7; i >= 0; i--)
                s.append((x >> i) & 1);
        return s.toString();
    }
}





