CEASER

public class CaesarCipher {
    public static void main(String[] args) {
        String text = "HELLO";
        int key = 3;

        String encrypt = "";
        for (char c : text.toCharArray()) {
            encrypt += (char) ((c - 'A' + key) % 26 + 'A');
        }

        String decrypt = "";
        for (char c : encrypt.toCharArray()) {
            decrypt += (char) ((c - 'A' - key + 26) % 26 + 'A');
        }

        System.out.println("Original: " + text);
        System.out.println("Encrypted: " + encrypt);
        System.out.println("Decrypted: " + decrypt);
    }
}


SUBSTITUTION 

public class SubstitutionCipher {
    public static void main(String[] args) {
        String plain = "HELLO";
        String key = "QWERTYUIOPASDFGHJKLZXCVBNM";

        String cipher = "";
        for (char c : plain.toCharArray()) {
            cipher += key.charAt(c - 'A');
        }

        String decrypt = "";
        for (char c : cipher.toCharArray()) {
            decrypt += (char) (key.indexOf(c) + 'A');
        }

        System.out.println("Plain: " + plain);
        System.out.println("Cipher: " + cipher);
        System.out.println("Decrypted: " + decrypt);
    }
}


AES

import javax.crypto.Cipher;
import javax.crypto.KeyGenerator;
import javax.crypto.SecretKey;
import java.util.Base64;

public class AESExample {
    public static void main(String[] args) throws Exception {
        String plainText = "HelloAES";
        KeyGenerator keyGen = KeyGenerator.getInstance("AES");
        keyGen.init(128);
        SecretKey key = keyGen.generateKey();

        Cipher cipher = Cipher.getInstance("AES");
        cipher.init(Cipher.ENCRYPT_MODE, key);
        byte[] encrypted = cipher.doFinal(plainText.getBytes());
        String encryptedText = Base64.getEncoder().encodeToString(encrypted);

        cipher.init(Cipher.DECRYPT_MODE, key);
        byte[] decrypted = cipher.doFinal(encrypted);
        String decryptedText = new String(decrypted);

        System.out.println("Original: " + plainText);
        System.out.println("Encrypted: " + encryptedText);
        System.out.println("Decrypted: " + decryptedText);
    }
}




DIFFIE HELLMAN KEY EXCHANGE

input id="p" value="23">
<input id="g" value="5">
<input id="a" placeholder="a">

<button onclick="c()">Compute</button>

<div id="o"></div>

<script>
f = (b, e, m) => {
    for (r = 1; e--; r = r * b % m);
    return r;
};

c = () => {
    p = +p.value;
    g = +g.value;
    a = +a.value;

    if (!p || !g || !a) return alert("Invalid");

    b = ~~(Math.random() * (p - 2)) + 1;
    A = f(g, a, p);
    B = f(g, b, p);

    o.innerHTML = `
        <p>Alice's public key (A): ${A}</p>
        <p>Bob's public key (B): ${B}</p>
        <p>Shared secret key (Alice's computation): ${f(B, a, p)}</p>
        <p>Shared secret key (Bob's computation): ${f(A, b, p)}</p>
    `;
};
</script>
